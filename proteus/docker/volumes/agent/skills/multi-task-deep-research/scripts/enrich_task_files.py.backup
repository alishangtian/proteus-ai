#!/usr/bin/env python3
"""
多任务深度研究文件丰富化脚本
支持第二步：依次丰富主任务文件和子任务文件，确保文件内容足够丰富
"""

import os
import json
import shutil
from datetime import datetime

def enrich_master_task_plan(task_dir, task_name, task_description):
    """
    丰富主任务规划文件
    
    Args:
        task_dir: 任务目录路径
        task_name: 任务名称
        task_description: 任务描述
    """
    
    master_plan_path = os.path.join(task_dir, "master_task_plan.md")
    current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # 读取现有内容或创建新内容
    if os.path.exists(master_plan_path):
        with open(master_plan_path, 'r', encoding='utf-8') as f:
            content = f.read()
    else:
        content = f"# 主任务规划: {task_name}\n\n## 总体目标\n{task_description}\n\n"
    
    # 检查并添加缺失的关键部分
    sections_to_add = []
    
    if "## 研究范围" not in content:
        sections_to_add.append("""
## 研究范围
### 包含范围
1. [在此定义研究范围，明确包含哪些方面]
2. [设定研究的边界和焦点]
3. [确定研究深度和广度]

### 排除范围
1. [在此定义排除范围，明确不包含哪些方面]
2. [设定限制条件和排除标准]
3. [说明为什么这些方面被排除]
""")
    
    if "## 方法论" not in content:
        sections_to_add.append("""
## 方法论
### 研究方法
1. **文献综述** - 收集和分析现有文献和研究报告
2. **多源验证** - 从多个独立来源验证关键信息
3. **专家访谈** - 引用领域专家观点和见解
4. **数据分析** - 对收集的数据进行定量和定性分析
5. **趋势预测** - 基于历史数据和当前趋势进行预测

### 质量保证
1. **来源可信度评估** - 评估信息源的权威性和可靠性
2. **交叉验证** - 通过多个独立来源验证关键发现
3. **偏见识别** - 识别和减少研究中的潜在偏见
4. **同行评审** - 重要发现经过同行评审验证
""")
    
    if "## 时间规划" not in content:
        sections_to_add.append(f"""
## 时间规划
### 阶段1: 规划与分解 (预计: 1-2天)
- 主任务规划完成
- 子任务分解完成
- 目录结构创建
- 任务配置初始化

### 阶段2: 文件丰富化 (预计: 0.5-1天)
- 主任务文件完善
- 子任务文件丰富
- 模板和示例添加
- 质量检查点设置

### 阶段3: 子任务执行 (预计: {len(os.listdir(os.path.join(task_dir, "sub_tasks"))) if os.path.exists(os.path.join(task_dir, "sub_tasks")) else 3}-5天)
- 所有子任务启动
- 并行研究执行
- 定期进度监控
- 质量检查点执行

### 阶段4: 结果整合 (预计: 1-2天)
- 子任务结果收集
- 综合分析与整合
- 矛盾解决和共识建立
- 最终报告生成

### 关键里程碑
1. **M1** - 规划完成: [日期]
2. **M2** - 文件丰富化完成: [日期]
3. **M3** - 子任务全部启动: [日期]
4. **M4** - 首个子任务完成: [日期]
5. **M5** - 所有子任务完成: [日期]
6. **M6** - 最终报告完成: [日期]
""")
    
    if "## 成功标准" not in content:
        sections_to_add.append("""
## 成功标准
### 定量标准
1. **完整性**: 所有子任务100%完成
2. **及时性**: 90%的任务在计划时间内完成
3. **质量评分**: 综合质量评分≥85/100
4. **用户满意度**: 用户满意度评分≥90%

### 定性标准
1. **洞察深度**: 研究提供新颖、深入的洞察
2. **实用性**: 建议具体、可行、可操作
3. **影响力**: 研究成果对决策有实际影响
4. **可复用性**: 研究方法和发现可被未来项目复用
""")
    
    # 添加缺失的部分
    if sections_to_add:
        content += "
" + "
".join(sections_to_add)
    
    # 更新时间戳
    content = content.replace("[YYYY-MM-DD HH:MM:SS]", current_time)
    
    # 确保有最后更新时间
    if "最后更新时间:" not in content:
        content += f"

---
*最后更新时间: {current_time}*
"
    
    with open(master_plan_path, 'w', encoding='utf-8') as f:
        f.write(content)
    
    print(f"✅ 主任务规划文件已丰富: {master_plan_path}")
    return True

def enrich_subtask_files(task_dir, subtask_name):
    """
    丰富子任务文件
    
    Args:
        task_dir: 任务目录路径
        subtask_name: 子任务名称
    """
    
    # 查找子任务目录
    subtasks_dir = os.path.join(task_dir, "sub_tasks")
    subtask_dirs = os.listdir(subtasks_dir) if os.path.exists(subtasks_dir) else []
    
    subtask_dir_path = None
    for dir_name in subtask_dirs:
        # 读取子任务配置或根据名称匹配
        config_path = os.path.join(task_dir, "task_config.json")
        if os.path.exists(config_path):
            with open(config_path, 'r', encoding='utf-8') as f:
                config = json.load(f)
            
            for subtask in config.get('subtasks', []):
                if subtask.get('name') == subtask_name:
                    subtask_dir_path = os.path.join(subtasks_dir, subtask.get('directory', dir_name))
                    break
        
        if subtask_dir_path and os.path.exists(subtask_dir_path):
            break
    
    if not subtask_dir_path or not os.path.exists(subtask_dir_path):
        print(f"⚠ 未找到子任务目录: {subtask_name}")
        return False
    
    current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # 1. 丰富 task_plan.md
    task_plan_path = os.path.join(subtask_dir_path, "task_plan.md")
    if os.path.exists(task_plan_path):
        with open(task_plan_path, 'r', encoding='utf-8') as f:
            task_plan_content = f.read()
        
        # 添加缺失的关键部分
        if "## 研究问题" not in task_plan_content:
            task_plan_content += """
## 研究问题
### 核心问题
1. [在此列出核心研究问题]
2. [问题应该具体、可回答、有针对性]
3. [每个问题应有明确的研究价值]

### 子问题
1. [将核心问题分解为具体的子问题]
2. [子问题应该更具体、更容易研究]
3. [子问题的答案应能帮助回答核心问题]
"""
        
        if "## 研究方法" not in task_plan_content:
            task_plan_content += """
## 研究方法
### 数据来源
1. **学术文献** - 相关领域的学术论文和研究报告
2. **行业报告** - 市场分析报告和行业白皮书
3. **新闻媒体** - 权威新闻媒体的相关报道
4. **专家观点** - 领域专家的访谈和观点
5. **原始数据** - 可获得的原始数据集和统计资料

### 分析框架
1. **SWOT分析** - 优势、劣势、机会、威胁分析
2. **PEST分析** - 政治、经济、社会、技术分析
3. **波特五力** - 行业竞争结构分析
4. **趋势分析** - 历史趋势识别和未来预测
5. **比较分析** - 与类似案例或竞争对手的比较

### 验证方法
1. **多源验证** - 从多个独立来源验证关键信息
2. **专家评审** - 重要发现请领域专家评审
3. **数据三角测量** - 使用多种方法验证同一结论
4. **敏感性分析** - 检查结论对假设的敏感性
"""
        
        if "## 预期输出" not in task_plan_content:
            task_plan_content += """
## 预期输出
### 核心发现
1. [列出预期的主要发现]
2. [每个发现应有数据支持]
3. [发现应回答研究问题]

### 数据可视化
1. **趋势图表** - 显示关键趋势的变化
2. **比较图表** - 显示不同选项的比较
3. **分布图表** - 显示数据的分布情况
4. **关系图表** - 显示变量之间的关系

### 推荐格式
1. **执行摘要** - 1-2段的核心发现摘要
2. **详细发现** - 按主题组织的详细发现
3. **数据附录** - 支持性数据和图表
4. **参考文献** - 引用和参考来源列表
"""
        
        # 更新时间戳
        task_plan_content = task_plan_content.replace("[YYYY-MM-DD HH:MM:SS]", current_time)
        
        with open(task_plan_path, 'w', encoding='utf-8') as f:
            f.write(task_plan_content)
        
        print(f"  ✅ 子任务规划文件已丰富: {task_plan_path}")
    
    # 2. 丰富 findings.md
    findings_path = os.path.join(subtask_dir_path, "findings.md")
    if os.path.exists(findings_path):
        with open(findings_path, 'r', encoding='utf-8') as f:
            findings_content = f.read()
        
        # 如果内容还很基础，添加更多结构
        if "[等待研究完成]" in findings_content or len(findings_content.strip()) < 500:
            enriched_findings = f"""# 研究发现: {subtask_name}

## 执行摘要
[在此提供1-2段的执行摘要，概括核心发现和关键洞察]

## 核心发现
### 发现1: [关键发现标题]
- **描述**: [详细描述发现]
- **证据**: [支持证据和数据]
- **意义**: [发现的重要性和意义]
- **来源**: [信息来源和引用]

### 发现2: [关键发现标题]
- **描述**: [详细描述发现]
- **证据**: [支持证据和数据]
- **意义**: [发现的重要性和意义]
- **来源**: [信息来源和引用]

### 发现3: [关键发现标题]
- **描述**: [详细描述发现]
- **证据**: [支持证据和数据]
- **意义**: [发现的重要性和意义]
- **来源**: [信息来源和引用]

## 详细分析
### 主题1: [分析主题]
#### 数据趋势
[描述数据趋势和模式]

#### 关键洞察
[从数据中提取的关键洞察]

#### 影响因素
[影响该趋势的主要因素]

### 主题2: [分析主题]
[类似结构...]

## 数据可视化
### 图表1: [图表标题]
- **类型**: [图表类型，如折线图、柱状图等]
- **数据**: [图表展示的数据]
- **洞察**: [从图表中得出的洞察]
- **建议**: [基于图表的建议]

### 图表2: [图表标题]
[类似结构...]

## 结论与建议
### 主要结论
1. [结论1: 基于发现的明确结论]
2. [结论2: 基于发现的明确结论]
3. [结论3: 基于发现的明确结论]

### 行动建议
1. **立即行动** (1-3个月)
   - [建议1: 具体、可操作的建议]
   - [建议2: 具体、可操作的建议]

2. **中期行动** (3-12个月)
   - [建议1: 具体、可操作的建议]
   - [建议2: 具体、可操作的建议]

3. **长期战略** (1年以上)
   - [建议1: 具体、可操作的建议]
   - [建议2: 具体、可操作的建议]

## 参考资料
### 数据来源
1. [来源1: 描述和链接]
2. [来源2: 描述和链接]
3. [来源3: 描述和链接]

### 参考文献
1. [文献1: 引用格式]
2. [文献2: 引用格式]
3. [文献3: 引用格式]

---
*最后更新: {current_time}*
*状态: 进行中*
"""
            
            with open(findings_path, 'w', encoding='utf-8') as f:
                f.write(enriched_findings)
            
            print(f"  ✅ 研究发现文件已丰富: {findings_path}")
    
    # 3. 丰富 progress.md
    progress_path = os.path.join(subtask_dir_path, "progress.md")
    if os.path.exists(progress_path):
        with open(progress_path, 'r', encoding='utf-8') as f:
            progress_content = f.read()
        
        # 添加更详细的进度跟踪结构
        if "## 详细里程碑" not in progress_content:
            detailed_milestones = f"""
## 详细里程碑
### 阶段1: 研究规划 (0-20%)
- [ ] 研究问题明确
- [ ] 研究方法确定
- [ ] 数据来源识别
- [ ] 分析框架建立

### 阶段2: 数据收集 (20-50%)
- [ ] 主要数据来源收集
- [ ] 次要数据来源收集
- [ ] 数据质量评估
- [ ] 数据预处理完成

### 阶段3: 数据分析 (50-80%)
- [ ] 初步分析完成
- [ ] 深入分析进行中
- [ ] 关键发现识别
- [ ] 洞察提取

### 阶段4: 报告撰写 (80-100%)
- [ ] 报告大纲完成
- [ ] 初稿撰写
- [ ] 修订和编辑
- [ ] 最终审查

## 质量检查点
### 检查点1: 研究规划审查
- **时间**: [规划完成后]
- **审查内容**: 研究问题、方法、框架
- **审查人**: [指定审查人]
- **状态**: 待审查

### 检查点2: 数据收集审查
- **时间**: [数据收集完成后]
- **审查内容**: 数据完整性、质量、来源
- **审查人**: [指定审查人]
- **状态**: 待审查

### 检查点3: 分析结果审查
- **时间**: [分析完成后]
- **审查内容**: 分析方法、结果、洞察
- **审查人**: [指定审查人]
- **状态**: 待审查

### 检查点4: 最终报告审查
- **时间**: [报告完成后]
- **审查内容**: 报告完整性、准确性、可读性
- **审查人**: [指定审查人]
- **状态**: 待审查

## 风险管理
### 已识别风险
| 风险 | 可能性 | 影响 | 缓解措施 | 状态 |
|------|--------|------|----------|------|
| 数据不足 | 中 | 高 | 识别备用数据源，调整研究范围 | 监控中 |
| 分析偏差 | 低 | 中 | 使用多种分析方法，专家评审 | 监控中 |
| 时间不足 | 中 | 高 | 优先处理关键问题，调整范围 | 监控中 |
| 质量不符 | 低 | 高 | 设置质量检查点，同行评审 | 监控中 |

## 资源使用
### 时间投入
- **规划阶段**: [小时]小时
- **收集阶段**: [小时]小时
- **分析阶段**: [小时]小时
- **报告阶段**: [小时]小时
- **总计**: [小时]小时

### 工具使用
1. **serper_search**: [使用次数]次搜索
2. **web_crawler**: [访问次数]个网页
3. **python_execute**: [执行次数]次分析

---
*最后更新: {current_time}*
"""
            
            progress_content += detailed_milestones
            with open(progress_path, 'w', encoding='utf-8') as f:
                f.write(progress_content)
            
            print(f"  ✅ 进度跟踪文件已丰富: {progress_path}")
    
    # 4. 创建 references 目录和示例文件
    references_dir = os.path.join(subtask_dir_path, "references")
    os.makedirs(references_dir, exist_ok=True)
    
    # 创建示例参考文件
    sample_references = os.path.join(references_dir, "sample_sources.md")
    if not os.path.exists(sample_references):
        with open(sample_references, 'w', encoding='utf-8') as f:
            f.write(f"""# 参考资料示例: {subtask_name}

## 推荐数据来源
### 学术数据库
1. **Google Scholar** - 学术文献搜索
2. **IEEE Xplore** - 技术领域论文
3. **ACM Digital Library** - 计算机科学文献
4. **PubMed** - 生物医学文献
5. **SSRN** - 社会科学研究网络

### 行业报告
1. **Gartner** - IT行业分析和预测
2. **Forrester** - 技术市场研究
3. **McKinsey** - 商业和管理洞察
4. **BCG** - 商业战略咨询
5. **Deloitte** - 行业趋势分析

### 新闻媒体
1. **Reuters** - 国际新闻和财经报道
2. **Bloomberg** - 商业和金融市场新闻
3. **The Economist** - 全球经济和商业分析
4. **Financial Times** - 财经新闻和分析
5. **Wall Street Journal** - 商业和财经新闻

### 政府数据
1. **World Bank** - 全球发展数据
2. **IMF** - 国际货币基金组织数据
3. **UN Data** - 联合国统计数据
4. **OECD** - 经济合作与发展组织数据
5. **各国统计局** - 国家统计数据

## 搜索关键词建议
### 核心关键词
1. [主要概念1]
2. [主要概念2]
3. [主要概念3]

### 扩展关键词
1. [相关术语1]
2. [相关术语2]
3. [相关术语3]

### 长尾关键词
1. [具体问题1]
2. [具体问题2]
3. [具体问题3]

## 评估标准
### 来源可信度评估
1. **权威性** - 来源是否是该领域的权威？
2. **准确性** - 信息是否准确、有数据支持？
3. **时效性** - 信息是否及时、最新？
4. **客观性** - 来源是否有明显偏见？
5. **覆盖度** - 是否全面覆盖主题？

### 信息质量评估
1. **相关性** - 信息是否直接相关？
2. **深度** - 信息是否有足够深度？
3. **新颖性** - 信息是否提供新见解？
4. **可操作性** - 信息是否可转化为行动？
5. **一致性** - 与其他来源是否一致？
""")
        
        print(f"  ✅ 参考资料目录已创建: {references_dir}")
    
    return True

def enrich_all_task_files(task_dir):
    """
    丰富所有任务文件
    
    Args:
        task_dir: 任务目录路径
    """
    
    print(f"🔧 开始丰富任务文件: {task_dir}")
    print("=" * 60)
    
    # 检查配置文件
    config_path = os.path.join(task_dir, "task_config.json")
    if not os.path.exists(config_path):
        print(f"⚠ 配置文件未找到: {config_path}")
        return False
    
    try:
        with open(config_path, 'r', encoding='utf-8') as f:
            config = json.load(f)
        
        task_name = config.get('task_name', '未知任务')
        task_description = config.get('task_description', '')
        
        print(f"📋 任务: {task_name}")
        print(f"📝 描述: {task_description[:100]}...")
        
        # 1. 丰富主任务文件
        print("
📄 步骤1: 丰富主任务文件")
        enrich_master_task_plan(task_dir, task_name, task_description)
        
        # 2. 丰富所有子任务文件
        print("
📄 步骤2: 丰富子任务文件")
        subtasks = config.get('subtasks', [])
        
        if not subtasks:
            print("ℹ 没有子任务需要丰富")
            return True
        
        print(f"🔍 找到 {len(subtasks)} 个子任务")
        
        for i, subtask in enumerate(subtasks, 1):
            subtask_name = subtask.get('name', f'子任务{i}')
            print(f"  {i}. 丰富子任务: {subtask_name}")
            enrich_subtask_files(task_dir, subtask_name)
        
        # 3. 更新配置
        config['enriched_at'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        config['enrichment_version'] = "1.0.0"
        
        with open(config_path, 'w', encoding='utf-8') as f:
            json.dump(config, f, indent=2, ensure_ascii=False)
        
        print(f"
✅ 所有任务文件丰富化完成!")
        print(f"📁 任务目录: {task_dir}")
        print(f"📝 配置文件已更新: {config_path}")
        
        return True
        
    except Exception as e:
        print(f"❌ 丰富文件时出错: {e}")
        import traceback
        traceback.print_exc()
        return False

if __name__ == "__main__":
    import sys
    import argparse
    
    parser = argparse.ArgumentParser(description="多任务深度研究文件丰富化脚本")
    parser.add_argument("task_dir", help="任务目录路径")
    parser.add_argument("--subtask", "-s", help="特定子任务名称（如未提供则处理所有子任务）")
    
    args = parser.parse_args()
    
    if not os.path.exists(args.task_dir):
        print(f"错误: 任务目录不存在: {args.task_dir}")
        sys.exit(1)
    
    print("=" * 60)
    print("📝 多任务深度研究文件丰富化系统")
    print("🎯 目标: 支持第二步执行模式 - 依次丰富主任务和子任务文件")
    print("📋 功能: 确保文件内容足够丰富，有明确的框架和指导")
    print("=" * 60)
    
    if args.subtask:
        # 丰富特定子任务
        success = enrich_subtask_files(args.task_dir, args.subtask)
    else:
        # 丰富所有任务文件
        success = enrich_all_task_files(args.task_dir)
    
    if success:
        print("
🎉 文件丰富化完成!")
        print("💡 下一步建议: 检查丰富后的文件，根据需要进一步定制")
    else:
        print("
❌ 文件丰富化失败")
        sys.exit(1)
