#!/usr/bin/env python3
"""
多任务深度研究子任务启动脚本 - 增强版
支持依赖关系的顺序启动，一次只启动一个任务
包含改进的错误处理和诊断功能
"""

import os
import json
import time
import sys
import socket
import urllib.parse
from datetime import datetime

