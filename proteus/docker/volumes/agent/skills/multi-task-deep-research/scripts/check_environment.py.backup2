#!/usr/bin/env python3
"""
多任务深度研究技能环境检查脚本
检查运行多任务深度研究所需的所有环境和配置
"""

import os
import sys
import json
import platform
import subprocess
import importlib
import time
from pathlib import Path

class EnvironmentChecker:
    """多任务深度研究技能环境检查器"""
    
    def __init__(self, verbose=True):
        self.verbose = verbose
        self.results = []
        self.skill_dir = Path("/app/.proteus/skills/multi-task-deep-research")
        self.issues = []
        self.warnings = []
        
    def log(self, message, level="INFO"):
        """记录日志"""
        prefix = {
            "INFO": "ℹ",
            "SUCCESS": "✓",
            "WARNING": "⚠",
            "ERROR": "✗"
        }.get(level, "ℹ")
        
        formatted = f"{prefix} {message}"
        self.results.append(f"[{level}] {message}")
        
        if self.verbose:
            print(formatted)
    
    def check_python_version(self):
        """检查Python版本"""
        required_version = (3, 8)
        current_version = sys.version_info
        
        if current_version >= required_version:
            self.log(f"Python版本检查通过: {sys.version.split()[0]}", "SUCCESS")
            return True
        else:
            self.log(f"Python版本过低: {sys.version.split()[0]} (需要 >= 3.8)", "ERROR")
            self.issues.append(f"Python版本需要 >= 3.8，当前为 {sys.version.split()[0]}")
            return False
    
    def check_required_packages(self):
        """检查必需的Python包"""
        required_packages = [
            "requests",      # API调用
            "json",         # JSON处理
            "os",           # 系统操作
            "re",           # 正则表达式
            "datetime",     # 时间处理
            "time",         # 时间相关
            "pathlib",      # 路径操作
        ]
        
        missing_packages = []
        
        for package in required_packages:
            try:
                importlib.import_module(package)
                self.log(f"包 {package} 可用", "SUCCESS")
            except ImportError:
                missing_packages.append(package)
                self.log(f"包 {package} 未安装", "ERROR")
        
        if missing_packages:
            self.issues.append(f"缺少必需的Python包: {', '.join(missing_packages)}")
            return False
        else:
            self.log("所有必需的Python包都可用", "SUCCESS")
            return True
    
    def check_skill_directory(self):
        """检查技能目录结构"""
        required_dirs = [
            "scripts",
            "templates", 
            "examples",
            "references"
        ]
        
        required_files = [
            "SKILL.md",
            "scripts/init_multi_task.py",
            "scripts/start_subtasks.py",
            "scripts/monitor_tasks.py",
            "scripts/integrate_results.py",
            "templates/task_config.json",
            "templates/master_task_plan.md",
            "templates/sub_task_template.md"
        ]
        
        # 检查根目录
        if not self.skill_dir.exists():
            self.log(f"技能目录不存在: {self.skill_dir}", "ERROR")
            self.issues.append(f"技能目录不存在: {self.skill_dir}")
            return False
        else:
            self.log(f"技能目录存在: {self.skill_dir}", "SUCCESS")
        
        # 检查必需的子目录
        missing_dirs = []
        for dir_name in required_dirs:
            dir_path = self.skill_dir / dir_name
            if dir_path.exists():
                self.log(f"目录 {dir_name} 存在", "SUCCESS")
            else:
                missing_dirs.append(dir_name)
                self.log(f"目录 {dir_name} 不存在", "WARNING")
                self.warnings.append(f"目录 {dir_name} 不存在")
        
        # 检查必需的文件
        missing_files = []
        for file_path in required_files:
            full_path = self.skill_dir / file_path
            if full_path.exists():
                self.log(f"文件 {file_path} 存在", "SUCCESS")
            else:
                missing_files.append(file_path)
                self.log(f"文件 {file_path} 不存在", "WARNING")
                self.warnings.append(f"文件 {file_path} 不存在")
        
        if missing_dirs or missing_files:
            self.log("目录结构不完整，但技能仍可能正常工作", "WARNING")
            return True  # 目录缺失是警告，不是错误
        else:
            self.log("技能目录结构完整", "SUCCESS")
            return True
    
    def check_file_permissions(self):
        """检查文件权限"""
        required_writable = [
            self.skill_dir,
            self.skill_dir / "scripts",
        ]
        
        permission_issues = []
        
        for path in required_writable:
            if path.exists():
                try:
                    # 尝试写入一个临时文件来测试权限
                    test_file = path / ".permission_test.tmp"
                    try:
                        test_file.write_text("test")
                        test_file.unlink()  # 删除测试文件
                        self.log(f"目录 {path.name} 可写", "SUCCESS")
                    except Exception as e:
                        permission_issues.append(str(path))
                        self.log(f"目录 {path.name} 不可写: {e}", "ERROR")
                except Exception as e:
                    self.log(f"检查 {path.name} 权限时出错: {e}", "WARNING")
        
        if permission_issues:
            self.issues.append(f"以下目录需要写权限: {', '.join(permission_issues)}")
            return False
        else:
            self.log("所有必需目录都有写权限", "SUCCESS")
            return True
    
    def check_api_configuration(self):
        """检查API配置"""
        config_path = self.skill_dir / "templates" / "task_config.json"
        
        if not config_path.exists():
            self.log("API配置文件不存在", "WARNING")
            self.warnings.append("API配置文件 templates/task_config.json 不存在")
            return True  # 这不是致命错误
        
        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                config = json.load(f)
            
            # 检查API配置部分
            if "api_config" not in config:
                self.log("配置文件中缺少api_config部分", "WARNING")
                self.warnings.append("配置文件中缺少api_config部分")
                return True
            
            api_config = config["api_config"]
            
            # 检查必需的API参数
            required_params = ["endpoint", "auth_token", "model_name", "selected_skills"]
            missing_params = []
            
            for param in required_params:
                if param not in api_config:
                    missing_params.append(param)
            
            if missing_params:
                self.log(f"API配置缺少参数: {', '.join(missing_params)}", "WARNING")
                self.warnings.append(f"API配置缺少参数: {', '.join(missing_params)}")
            else:
                self.log("API配置参数完整", "SUCCESS")
            
            # 检查技能名称是否正确
            if "selected_skills" in api_config:
                skills = api_config["selected_skills"]
                if isinstance(skills, list):
                    if "planning-with-files" in skills:
                        self.log("技能名称正确: planning-with-files (复数形式)", "SUCCESS")
                    elif "planning-with-file" in skills:
                        self.log("技能名称有误: planning-with-file (应为复数形式)", "ERROR")
                        self.issues.append("API配置中的技能名称应为 'planning-with-files' (复数)")
                    else:
                        self.log(f"技能列表: {skills}", "INFO")
            
            return True
            
        except json.JSONDecodeError as e:
            self.log(f"API配置文件JSON格式错误: {e}", "ERROR")
            self.issues.append(f"API配置文件JSON格式错误: {e}")
            return False
        except Exception as e:
            self.log(f"检查API配置时出错: {e}", "ERROR")
            self.issues.append(f"检查API配置时出错: {e}")
            return False
    
    def check_dependent_skills(self):
        """检查依赖的其他技能"""
        # 多任务深度研究可能依赖的其他技能
        dependent_skills = [
            "planning-with-files",  # 基础文件规划模式
            "deep-research",        # 深度研究方法论
        ]
        
        skills_dir = Path("/app/.proteus/skills")
        missing_skills = []
        
        for skill in dependent_skills:
            skill_path = skills_dir / skill
            if skill_path.exists() and (skill_path / "SKILL.md").exists():
                self.log(f"依赖技能 {skill} 存在", "SUCCESS")
            else:
                missing_skills.append(skill)
                self.log(f"依赖技能 {skill} 不存在", "WARNING")
                self.warnings.append(f"依赖技能 {skill} 不存在")
        
        if missing_skills:
            self.log(f"缺少以下依赖技能: {', '.join(missing_skills)}", "WARNING")
            self.log("注意: 缺少依赖技能可能影响功能完整性", "WARNING")
        
        return True  # 依赖技能缺失不是致命错误
    
    def test_api_connection(self):
        """测试API连接（可选）"""
        config_path = self.skill_dir / "templates" / "task_config.json"
        
        if not config_path.exists():
            self.log("跳过API连接测试（无配置文件）", "INFO")
            return True
        
        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                config = json.load(f)
            
            if "api_config" not in config:
                self.log("跳过API连接测试（无API配置）", "INFO")
                return True
            
            api_config = config["api_config"]
            endpoint = api_config.get("endpoint", "")
            
            if not endpoint:
                self.log("跳过API连接测试（无endpoint）", "INFO")
                return True
            
            # 如果是本地端点，检查服务是否运行
            if "127.0.0.1" in endpoint or "localhost" in endpoint:
                try:
                    import requests
                    # 尝试健康检查端点（如果有）
                    health_endpoint = endpoint.replace("/task", "/health")
                    response = requests.get(health_endpoint, verify=False, timeout=5)
                    if response.status_code == 200:
                        self.log(f"API服务运行正常: {endpoint}", "SUCCESS")
                    else:
                        self.log(f"API服务返回 {response.status_code}，可能未正常运行", "WARNING")
                        self.warnings.append(f"API服务返回 {response.status_code}")
                except requests.exceptions.ConnectionError:
                    self.log(f"无法连接到API服务 {endpoint}，请确保服务已启动", "WARNING")
                    self.warnings.append(f"无法连接到API服务 {endpoint}")
                except Exception as e:
                    self.log(f"API连接测试出错: {e}", "WARNING")
                    self.warnings.append(f"API连接测试出错: {e}")
            else:
                self.log(f"外部API端点: {endpoint}（连接测试跳过）", "INFO")
            
            return True
            
        except Exception as e:
            self.log(f"API连接测试过程中出错: {e}", "WARNING")
            self.warnings.append(f"API连接测试过程中出错: {e}")
            return True  # API连接失败不是致命错误
    
    def check_execution_scripts(self):
        """检查执行脚本"""
        required_scripts = [
            "init_multi_task.py",
            "start_subtasks.py", 
            "monitor_tasks.py",
            "integrate_results.py"
        ]
        
        script_issues = []
        
        for script in required_scripts:
            script_path = self.skill_dir / "scripts" / script
            
            if not script_path.exists():
                self.log(f"脚本 {script} 不存在", "ERROR")
                script_issues.append(script)
                continue
            
            # 检查脚本语法
            try:
                with open(script_path, 'r', encoding='utf-8') as f:
                    content = f.read()
                
                # 简单语法检查：尝试编译
                compile(content, script, 'exec')
                self.log(f"脚本 {script} 语法正确", "SUCCESS")
                
                # 检查脚本是否包含必要的导入
                required_imports = []
                if script == "init_multi_task.py":
                    required_imports = ["os", "json", "datetime", "shutil", "re"]
                elif script == "start_subtasks.py":
                    required_imports = ["os", "json", "requests", "datetime", "time", "sys"]
                
                missing_imports = []
                for imp in required_imports:
                    if f"import {imp}" not in content and f"from {imp}" not in content:
                        missing_imports.append(imp)
                
                if missing_imports:
                    self.log(f"脚本 {script} 可能缺少导入: {', '.join(missing_imports)}", "WARNING")
                    self.warnings.append(f"脚本 {script} 可能缺少导入: {', '.join(missing_imports)}")
                
            except SyntaxError as e:
                self.log(f"脚本 {script} 语法错误: {e}", "ERROR")
                script_issues.append(f"{script} (语法错误)")
            except Exception as e:
                self.log(f"检查脚本 {script} 时出错: {e}", "WARNING")
                self.warnings.append(f"检查脚本 {script} 时出错: {e}")
        
        if script_issues:
            self.issues.append(f"脚本问题: {', '.join(script_issues)}")
            return False
        else:
            self.log("所有执行脚本语法正确", "SUCCESS")
            return True
    
    def generate_report(self):
        """生成检查报告"""
        report_lines = []
        report_lines.append("=" * 60)
        report_lines.append("多任务深度研究技能 - 环境检查报告")
        report_lines.append(f"检查时间: {time.strftime('%Y-%m-%d %H:%M:%S')}")
        report_lines.append(f"系统: {platform.system()} {platform.release()}")
        report_lines.append(f"Python: {sys.version}")
        report_lines.append("=" * 60)
        
        # 添加检查结果
        report_lines.append("\n检查结果摘要:")
        
        error_count = len(self.issues)
        warning_count = len(self.warnings)
        
        if error_count == 0 and warning_count == 0:
            report_lines.append("✓ 环境检查通过，所有条件满足")
        else:
            report_lines.append(f"⚠ 发现 {error_count} 个错误，{warning_count} 个警告")
        
        # 详细结果
        report_lines.append("
详细检查记录:")
        for result in self.results:
            report_lines.append(f"  {result}")
        
        # 问题列表
        if self.issues:
            report_lines.append("
❌ 需要修复的问题:")
            for issue in self.issues:
                report_lines.append(f"  • {issue}")
        
        if self.warnings:
            report_lines.append("
⚠ 需要注意的警告:")
            for warning in self.warnings:
                report_lines.append(f"  • {warning}")
        
        # 建议
        report_lines.append("
💡 建议:")
        if self.issues:
            report_lines.append("  1. 首先解决上述错误问题")
            report_lines.append("  2. 然后处理警告问题")
        elif self.warnings:
            report_lines.append("  1. 处理上述警告以优化环境")
        else:
            report_lines.append("  1. 环境状态良好，可以正常使用多任务深度研究技能")
        
        report_lines.append("
📋 使用建议:")
        report_lines.append("  1. 定期运行此脚本检查环境")
        report_lines.append("  2. 查看 /app/data/tasks/ 目录权限")
        report_lines.append("  3. 确保API服务正常运行（如果使用外部API）")
        
        report_lines.append("
SKIP_THIS_LINE        
        report_text = "
".join(report_lines)
        
        # 保存报告到文件
        report_dir = self.skill_dir / "reports"
        report_dir.mkdir(exist_ok=True)
        
        timestamp = time.strftime("%Y%m%d_%H%M%S")
        report_file = report_dir / f"environment_check_{timestamp}.md"
        
        with open(report_file, 'w', encoding='utf-8') as f:
            f.write(report_text)
        
        self.log(f"详细报告已保存到: {report_file}", "INFO")
        
        return report_text, error_count, warning_count
    
    def run_all_checks(self):
        """运行所有检查"""
        print("🔍 开始多任务深度研究技能环境检查...")
        print()
        
        checks = [
            ("Python版本检查", self.check_python_version),
            ("必需包检查", self.check_required_packages),
            ("技能目录结构检查", self.check_skill_directory),
            ("文件权限检查", self.check_file_permissions),
            ("API配置检查", self.check_api_configuration),
            ("依赖技能检查", self.check_dependent_skills),
            ("执行脚本检查", self.check_execution_scripts),
            ("API连接测试", self.test_api_connection),
        ]
        
        for check_name, check_func in checks:
            print(f"正在检查: {check_name}...")
            check_func()
            print()
        
        # 生成报告
        report, error_count, warning_count = self.generate_report()
        
        print("=" * 60)
        print("环境检查完成!")
        print()
        
        if error_count == 0:
            print("✅ 环境检查通过，多任务深度研究技能可以正常使用")
        else:
            print(f"❌ 发现 {error_count} 个错误，请修复后再使用")
        
        if warning_count > 0:
            print(f"⚠  有 {warning_count} 个警告，建议处理以优化体验")
        
        print("详细报告已保存到技能目录的 reports/ 文件夹中")
        
        return error_count == 0

def main():
    """主函数"""
    checker = EnvironmentChecker(verbose=True)
    success = checker.run_all_checks()
    
    # 返回适当的退出代码
    sys.exit(0 if success else 1)

if __name__ == "__main__":
    main()
