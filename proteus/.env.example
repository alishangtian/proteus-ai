REDIS_SSL_KEYFILE=/app/data/redis_certs/client.key  # 客户端私钥路径（可选）
REDIS_SSL_CERT_REQS=required  # 证书验证级别，可选值：required, optional, none（默认required）
REDIS_SSL_CHECK_HOSTNAME=true  # 是否检查主机名匹配，可选值：true/1/yes（默认true）

