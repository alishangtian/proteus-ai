# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=proteus123
REDIS_DB=0
# Redis连接池配置
REDIS_MAX_CONNECTIONS=20
# Redis TLS配置（可选）
REDIS_TLS=false  # 启用TLS连接，可选值：true/1/yes
REDIS_SSL_CA_CERTS=ssl/ca.crt  # CA证书路径（可选）
REDIS_SSL_CERTFILE=ssl/client.crt  # 客户端证书路径（可选）
REDIS_SSL_KEYFILE=ssl/client.key  # 客户端私钥路径（可选）
REDIS_SSL_CERT_REQS=required  # 证书验证级别，可选值：required, optional, none（默认required）
REDIS_SSL_CHECK_HOSTNAME=true  # 是否检查主机名匹配，可选值：true/1/yes（默认true）

# 会话存储模式 (redis/file)
SESSION_MODEL=redis

# 可选：日志级别
LOG_LEVEL=INFO

 # 可选：日志文件路径
 LOG_FILE=logs/app.log


# 可选：模型配置文件路径（自动查找，无需配置）
# MODEL_CONFIG_PATH=conf/models_config.yaml

# Langfuse 配置
LANGFUSE_SECRET_KEY=sk-lf-2**************b4-6c12c18141b5
LANGFUSE_PUBLIC_KEY=pk-lf-9**************-93d8-723f28b3e180
LANGFUSE_BASE_URL=http://127.0.0.1:3000
LANGFUSE_HOST=http://host.docker.internal:3000
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_AUTO_INIT=true
